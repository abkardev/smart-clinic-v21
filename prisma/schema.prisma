// This is your Prisma schema file for SmartClinic
// Database: PostgreSQL
// Generated from: Mongoose/MongoDB models (smartclinic-v11)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  superadmin
  admin
  doctor
}

enum UserStatus {
  pending
  approved
  rejected
  suspended
}

enum PreferredLang {
  en
  ar
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  no_show   @map("no-show")
  completed
}

enum BookingSource {
  whatsapp
  dashboard
  api
  instagram
}

enum HolidayType {
  weekly
  date
}

enum AuditStatus {
  success
  failure
}

enum WhatsAppStep {
  main_menu
  select_doctor
  select_service
  select_date
  select_time
  ask_name
  ask_whatsapp
  ask_call_time
  offers
  booking_summary
  done
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  password             String
  role                 UserRole      @default(admin)
  status               UserStatus    @default(pending)
  preferredLang        PreferredLang @default(en)

  // Relations (foreign keys)
  doctorId             String?       // link if role=doctor
  doctor               Doctor?       @relation("UserDoctor", fields: [doctorId], references: [id])

  approvedById         String?
  approvedBy           User?         @relation("UserApprovedBy", fields: [approvedById], references: [id])
  approvedAt           DateTime?

  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  lastLogin            DateTime?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Reverse relations
  approvedUsers        User[]        @relation("UserApprovedBy")
  createdOffers        Offer[]       @relation("OfferCreatedBy")
  createdHolidays      Holiday[]     @relation("HolidayCreatedBy")
  blockedSlots         BlockedSlot[] @relation("BlockedSlotBlockedBy")
  auditLogs            AuditLog[]    @relation("AuditLogUser")

  @@index([resetPasswordToken])
  @@map("users")
}

model Doctor {
  id           String   @id @default(cuid())
  nameEn       String
  nameAr       String
  specialtyEn  String?
  specialtyAr  String?
  phone        String?
  email        String?   @unique
  calendarId   String

  // Working hours stored as simple strings (HH:MM)
  workingStart String   @default("09:00")
  workingEnd   String   @default("17:00")

  // Working days stored as int[] (0=Sun, 1=Mon … 6=Sat)
  workingDays  Int[]    @default([0, 1, 2, 3, 4])

  // Break time
  breakEnabled  Boolean @default(false)
  breakStart    String  @default("13:00")
  breakEnd      String  @default("14:00")
  breakDuration Int     @default(60) // minutes

  slotDuration  Int     @default(30) // minutes
  isActive      Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  bookings     Booking[]     @relation("BookingDoctor")
  blockedSlots BlockedSlot[] @relation("BlockedSlotDoctor")
  linkedUsers  User[]        @relation("UserDoctor")
  holidays     HolidayDoctor[]

  @@map("doctors")
}

model Booking {
  id              String        @id @default(cuid())
  name            String
  phone           String
  service         String
  date            String        // YYYY-MM-DD (kept as string to match original)
  time            String        // HH:MM
  status          BookingStatus @default(pending)
  priority        String        @default("regular") // emergency, vip, regular, follow_up
  notes           String?

  doctorId        String
  doctor          Doctor        @relation("BookingDoctor", fields: [doctorId], references: [id])

  // Google Calendar sync
  calendarEventId     String?
  calendarLink        String?
  calendarSynced      Boolean       @default(false)
  calendarLastSyncedAt DateTime?

  // WhatsApp
  reminderSent    Boolean       @default(false)
  reminderSentAt  DateTime?

  // Source
  source          BookingSource @default(dashboard)

  // Instagram PSID for My Booking lookup (set only for Instagram-sourced bookings)
  instagramPsid   String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Prevent double bookings (replaces Mongoose compound unique index)
  @@unique([doctorId, date, time])
  @@index([doctorId, date])
  @@index([phone])
  @@index([status])
  @@index([instagramPsid])
  @@index([date])                         // Accelerates dashboard date-range queries + calendar filtering
  @@index([source])                       // Accelerates dashboard WhatsApp/Instagram booking counts
  @@index([service])                      // Accelerates analytics service-grouped aggregations
  @@index([doctorId, date, status])       // Accelerates availability slot calculation queries
  @@map("bookings")
}

model BlockedSlot {
  id            String   @id @default(cuid())
  doctorId      String
  doctor        Doctor   @relation("BlockedSlotDoctor", fields: [doctorId], references: [id])
  date          String   // YYYY-MM-DD
  time          String?  // HH:MM — null means whole day blocked
  reason        String   @default("")
  isWholeDay    Boolean  @default(false)
  syncedToGoogle Boolean @default(false)
  googleEventId String?

  blockingSource  String  @default("manual") // manual | google_import | recurring_expansion

  blockedById   String?
  blockedBy     User?    @relation("BlockedSlotBlockedBy", fields: [blockedById], references: [id])

  recurringSlotId String?
  recurringSlot   RecurringBlockedSlot? @relation(fields: [recurringSlotId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([doctorId, date])
  @@index([recurringSlotId])
  @@map("blocked_slots")
}

model Offer {
  id            String    @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String?
  descriptionAr String?
  imageUrl      String?
  imageBase64   String?   // base64 for WhatsApp/IG display
  code          String?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?

  createdById   String?
  createdBy     User?     @relation("OfferCreatedBy", fields: [createdById], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("offers")
}

model Holiday {
  id         String      @id @default(cuid())
  type       HolidayType
  dayOfWeek  Int?        // 0=Sun..6=Sat — for weekly holidays
  date       String?     // YYYY-MM-DD — for specific date holidays
  nameEn     String      @default("")
  nameAr     String      @default("")
  applyToAll Boolean     @default(true)

  // Specific doctors (many-to-many via join table)
  doctors    HolidayDoctor[]

  createdById String?
  createdBy   User?    @relation("HolidayCreatedBy", fields: [createdById], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("holidays")
}

// Join table: Holiday <-> Doctor (for applyToAll=false cases)
model HolidayDoctor {
  holidayId  String
  holiday    Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@id([holidayId, doctorId])
  @@map("holiday_doctors")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation("AuditLogUser", fields: [userId], references: [id])
  userName  String?
  userEmail String?
  action    String      // e.g. 'BOOKING_CREATED', 'USER_UPDATED'
  category  String?     // 'BOOKING' | 'AUTH' | 'DOCTOR' | 'SYSTEM' | 'OFFERS' | 'SETTINGS'
  severity  String?     // 'INFO' | 'WARNING' | 'ERROR' | 'CRITICAL'
  entity    String?     // e.g. 'Booking', 'Doctor', 'User'
  entityId  String?
  details   Json?       // before/after or extra info (replaces Mixed)
  ip        String?
  userAgent String?
  status    AuditStatus @default(success)

  correlationId String?
  bookingId     String?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([correlationId])
  @@index([entity, entityId])
  @@index([severity])
  @@map("audit_logs")
}

model WhatsAppSession {
  id             String       @id @default(cuid())
  phone          String       @unique
  step           WhatsAppStep @default(main_menu)

  // Session data (stored as JSON — replaces nested Mongoose sub-doc)
  data           Json         @default("{}")

  // Optimistic locking — incremented on every write, checked on update
  sessionVersion Int          @default(1)

  expiresAt      DateTime     @default(dbgenerated("NOW() + INTERVAL '30 minutes'"))

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([expiresAt])
  @@map("whatsapp_sessions")
}

// ─── Message deduplication (Phases 1-2) ──────────────────────────────────────
model ProcessedMessage {
  messageId   String   @id
  source      String   // 'whatsapp' | 'instagram'
  userId      String   // phone or ig_<id>
  processedAt DateTime @default(now())
  expiresAt   DateTime

  @@index([processedAt])
  @@map("processed_messages")
}

// ─── Conversation analytics (Phase 5) ─────────────────────────────────────────
model ConversationEvent {
  id               String   @id @default(cuid())
  conversationId   String
  userId           String
  platform         String   // 'whatsapp' | 'instagram'
  currentState     String?
  previousState    String?
  eventType        String   // 'TEXT' | 'LIST_REPLY' | 'NAVIGATION' | 'SYSTEM'
  payloadId        String?
  isText           Boolean
  executionTimeMs  Int?
  success          Boolean  @default(true)
  errorMessage     String?
  bookingCreated   Boolean  @default(false)
  bookingId        String?
  bookingCancelled Boolean  @default(false)
  sessionExpired   Boolean  @default(false)
  correlationId    String?
  messageId        String?
  webhookId        String?
  createdAt        DateTime @default(now())

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("conversation_events")
}

// ─── Fallback numbered-list mapping (persistent replacement for in-memory Map) ─
model FallbackMapping {
  userId    String   @id
  rows      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("fallback_mappings")
}

// ─── Rate limiting (Phase 7) ──────────────────────────────────────────────────
model RateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
  @@map("rate_limits")
}

// ─── Idempotency lock (Phase 2) ───────────────────────────────────────────────
model IdempotencyLock {
  key         String   @id
  bookingId   String?
  status      String   @default("locked") // 'locked' | 'completed' | 'failed'
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@map("idempotency_locks")
}

// ─── Calendar Sync Retry Queue ──────────────────────────────────────────────────
enum CalendarSyncStatus {
  pending
  processing
  completed
  failed
}

model CalendarSyncJob {
  id          String             @id @default(cuid())
  bookingId   String
  doctorId    String
  attempt     Int                @default(0)
  status      CalendarSyncStatus @default(pending)
  error       String?
  nextRetryAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, nextRetryAt])
  @@index([bookingId])
  @@map("calendar_sync_jobs")
}

// ─── Calendar Channel (push notification watch) ─────────────────────────────────
enum CalendarChannelStatus {
  active
  expiring
  stopped
  error
}

model CalendarChannel {
  id            String                 @id @default(cuid())
  doctorId      String
  calendarId    String
  channelId     String                 @unique
  resourceId    String                 @unique
  expiration    DateTime
  status        CalendarChannelStatus  @default(active)
  lastRenewedAt DateTime               @default(now())
  expiresAt     DateTime
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([doctorId])
  @@index([expiration])
  @@index([status])
  @@map("calendar_channels")
}

// ─── Calendar Sync State (syncToken per doctor) ─────────────────────────────────
model CalendarSyncState {
  id            String   @id @default(cuid())
  doctorId      String   @unique
  calendarId    String
  syncToken     String?
  fullSyncAt    DateTime @default(now())
  lastEventId   String?
  lastSyncAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("calendar_sync_states")
}

// ─── Doctor Calendar Token (per-doctor OAuth) ───────────────────────────────────
model DoctorCalendarToken {
  id            String   @id @default(cuid())
  doctorId      String   @unique
  calendarId    String?
  accessToken   String?
  refreshToken  String?
  tokenExpiresAt DateTime?
  scope         String?
  connectedAt   DateTime?
  disconnectedAt DateTime?
  status        String   @default("active") // active | disconnected | revoked
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("doctor_calendar_tokens")
}

// ─── Recurring Blocked Slot (RRULE support) ─────────────────────────────────────
enum RecurringSlotType {
  out_of_office
  vacation
  meeting
  personal
  conference
  other
}

model RecurringBlockedSlot {
  id            String            @id @default(cuid())
  doctorId      String
  title         String?
  rrule         String            // RFC 5545 RRULE (e.g. "FREQ=WEEKLY;BYDAY=MO,WE;COUNT=10")
  slotType      RecurringSlotType @default(other)
  startTime     String            // HH:MM
  endTime       String            // HH:MM
  isWholeDay    Boolean           @default(false)
  reason        String            @default("")
  googleEventId String?
  syncedToGoogle Boolean          @default(false)
  activeFrom    DateTime?
  activeUntil   DateTime?
  blockedSlots  BlockedSlot[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([doctorId])
  @@map("recurring_blocked_slots")
}

// ─── Calendar Retry Lock (distributed, singleton row) ───────────────────────────
model CalendarRetryLock {
  id        String   @id @default("singleton")
  lockedAt  DateTime @default(now())
  expiresAt DateTime
  instance  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("calendar_retry_lock")
}

// ─── Processed Notifications (distributed dedup cache) ──────────────────────────
model ProcessedNotification {
  id             String   @id @default(cuid())
  notificationKey String  @unique // channelId::resourceId::messageNumber
  channelId      String
  resourceId     String
  messageNumber  Int
  processedAt    DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
  @@index([processedAt])
  @@map("processed_notifications")
}

// ─── Calendar Configuration (persisted settings, singleton) ────────────────────
model CalendarConfig {
  id    String @id @default("singleton")
  config Json   @default("{}")

  @@map("calendar_config")
}

// ─── Service Buffer Rules (configurable buffers per service/doctor) ────────────
model ServiceBufferRule {
  id           String   @id @default(cuid())
  doctorId     String
  service      String   // matches Booking.service
  bufferBefore Int      @default(0) // minutes before appointment
  bufferAfter  Int      @default(0) // minutes after appointment
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([doctorId, service])
  @@index([doctorId])
  @@map("service_buffer_rules")
}

// ─── Waiting List ──────────────────────────────────────────────────────────────
model WaitingListEntry {
  id              String   @id @default(cuid())
  name            String
  phone           String
  service         String
  doctorId        String?
  priority        Int      @default(0) // higher = more urgent
  preferredDays   String[] @default([]) // MO,TU,WE,...
  preferredTimes  String?  // "morning" | "afternoon" | "evening"
  notes           String?
  status          String   @default("waiting") // waiting, reserved, booked, expired, cancelled
  expiresAt       DateTime?
  reservedAt      DateTime?
  bookedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([doctorId])
  @@index([createdAt])
  @@map("waiting_list_entries")
}

// ─── Appointment Team (multi-doctor appointments) ──────────────────────────────
model AppointmentTeam {
  id            String   @id @default(cuid())
  bookingId     String
  primaryDoctorId String
  teamMembers   Json     @default("[]") // Array<{ doctorId, role }>
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([bookingId])
  @@index([primaryDoctorId])
  @@map("appointment_teams")
}
