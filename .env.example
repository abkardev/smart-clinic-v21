# ═══════════════════════════════════════════════════════════════════════════════
# SmartClinic — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Required = application will not start without this variable
# Optional = application starts but the feature will be disabled
#
# 🔴 = Required
# 🟡 = Optional (recommended)
# ⚪ = Optional
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
# 🔴 PostgreSQL connection string.
#    For Neon (serverless Postgres):
#      Use the POOLED connection string (includes "-pooler" in the hostname).
#      The direct connection exhausts Neon's small connection pool under load.
#    Format:
#      postgresql://user:password@host:port/database?sslmode=require
#    Example (Neon pooled):
#      postgresql://myuser:mypassword@ep-silent-abc-123456-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
#    Example (local):
#      postgresql://postgres:postgres@localhost:5432/smartclinic
DATABASE_URL=

# ─── Authentication ──────────────────────────────────────────────────────────
# 🔴 Secret key for signing JWT tokens.
#    Generate with: openssl rand -hex 32
#    Minimum 32 characters, use a cryptographically random string.
#    Never commit this value to version control.
#    Example: 7f8a9b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f
JWT_SECRET=

# ─── Sentry (Error Tracking) ─────────────────────────────────────────────────
# 🟡 Sentry DSN for client-side error tracking.
#    Found in your Sentry project settings under "Client Keys (DSN)".
#    If not set, errors will still be logged to console but not sent to Sentry.
#    Example: https://abc123def456@o123456.ingest.sentry.io/1234567
NEXT_PUBLIC_SENTRY_DSN=

# 🟡 Sentry DSN for server-side error tracking.
#    Usually the same DSN as the client DSN.
SENTRY_DSN=

# ─── WhatsApp Cloud API ──────────────────────────────────────────────────────
# 🔴 WhatsApp permanent access token.
#    Generated from Meta Business Suite > WhatsApp > API Setup.
WHATSAPP_TOKEN=

# 🔴 WhatsApp Phone Number ID.
#    Found in Meta Business Suite > WhatsApp > API Setup.
#    Format: A 15-20 digit number (e.g. 123456789012345)
WHATSAPP_PHONE_ID=

# ⚪ Webhook verification token.
#    Set this to any string you choose. It must match the token you configure
#    in the Meta Business Suite webhook settings.
#    Default: (empty — webhook verification will be disabled)
#    Example: my_webhook_secret_2024
WHATSAPP_VERIFY_TOKEN=

# 🟡 App Secret for webhook signature verification.
#    Found in Meta Business Suite > Apps > Your App > Settings > Basic.
#    If set, incoming webhooks will be verified using HMAC-SHA256 signatures.
WHATSAPP_APP_SECRET=

# ─── Instagram Graph API ─────────────────────────────────────────────────────
# 🔴 Instagram permanent access token.
#    Generated from Meta Business Suite > Instagram > API.
#    Has format: IGQVJ... (long base64 string)
INSTAGRAM_TOKEN=

# ⚪ Webhook verification token for Instagram.
#    Must match the token configured in Meta Business Suite webhook settings.
#    Default: (empty — webhook verification disabled)
INSTAGRAM_VERIFY_TOKEN=

# 🟡 App Secret for Instagram webhook signature verification.
INSTAGRAM_APP_SECRET=

# ─── Google Calendar (Required for Calendar Sync) ──────────────────────────────
# 🔴 OAuth 2.0 Client ID from Google Cloud Console.
#    Found in: APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
#    Format: xxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# 🔴 OAuth 2.0 Client Secret from Google Cloud Console.
#    Found in: APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
#    Format: GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=

# 🔴 Refresh token for offline access to Google Calendar.
#    Must be generated with access_type=offline and prompt=consent.
#    The refresh_token is only returned on the FIRST authorization.
#    Generate via: https://developers.google.com/oauthplayground
#    Format: 1//0gxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=

# 🔴 OAuth redirect URI — must match Google Cloud Console exactly.
#    Development:  http://localhost:3000/api/google/oauth2callback
#    Production:   https://your-app.vercel.app/api/google/oauth2callback
#    IMPORTANT: Also register {uri}?doctorId=* as a second redirect URI
#    for per-doctor OAuth flows.
GOOGLE_REDIRECT_URI=

# 🔴 App base URL — used to derive the webhook URL and OAuth redirects.
#    Development:  http://localhost:3000
#    Production:   https://your-app.vercel.app
#    Webhook URL derived as: {NEXT_PUBLIC_APP_URL}/api/google/webhook
#    This must be publicly accessible for push notifications to work.
NEXT_PUBLIC_APP_URL=

# ─── Google Calendar Rate Limiting (Optional Tuning) ──────────────────────────
# ⚪ Google Calendar API requests per second (self-enforced).
#    Default: 10
# GOOGLE_RATE_LIMIT_RPS=10

# ⚪ Daily request quota for Google Calendar API (self-enforced).
#    Default: 1000000
#    Must be at or below the project quota in GCP Console → Quotas.
# GOOGLE_DAILY_QUOTA=1000000

# ⚪ Token bucket burst size for rate limiting.
#    Default: 20
# GOOGLE_BURST_LIMIT=20

# ⚪ Quota usage alert threshold (0.0 to 1.0).
#    Default: 0.8 (80%)
# GOOGLE_QUOTA_ALERT_AT=0.8

# ─── Storage (Optional) ──────────────────────────────────────────────────────
# ⚪ Vercel Blob storage token for offer images.
#    Generated from Vercel Dashboard > Storage > Blob.
BLOB_READ_WRITE_TOKEN=

# ─── Logging ─────────────────────────────────────────────────────────────────
# ⚪ Log level filter. Messages below this level are suppressed.
#    Values: trace, debug, info, warn, error
#    Default: debug (development), info (production)
#    Example: warn
LOG_LEVEL=

# ─── Booking Engine ──────────────────────────────────────────────────────────
# ⚪ IANA timezone for slot calculations.
#    Default: Asia/Riyadh
#    Example: America/New_York
CLINIC_TIMEZONE=

# ⚪ Minutes buffer before each slot (applies to today's date only).
#    Helps prevent last-minute bookings when the slot has already passed.
#    Default: 0
#    Example: 30
BOOKING_BUFFER_MINUTES=

# ⚪ Minimum hours before an appointment can be booked (today only).
#    Prevents bookings too close to the appointment time.
#    Default: 3
#    Example: 6
MINIMUM_ADVANCE_BOOKING_HOURS=

# ─── Calendar Retry Scheduler ─────────────────────────────────────────────────
# 🔴 Internal secret for authenticating the retry worker endpoint.
#    Generate with: openssl rand -hex 32
#    The scheduler (Vercel Cron / Docker / Linux cron) sends this as:
#      Authorization: Bearer <CALENDAR_INTERNAL_SECRET>
#    Must match the value set in the deployment environment.
CALENDAR_INTERNAL_SECRET=

# ⚪ Number of retry jobs to process per execution.
#    Default: 10
#    Increase for larger clinics with many bookings.
#    Example: 25
CALENDAR_RETRY_BATCH_SIZE=10

# ⚪ Set to 'true' to enable the automatic retry scheduler.
#    When disabled, the health endpoint reports it as inactive,
#    but the retry endpoint can still be called manually by admins.
#    Default: true
CALENDAR_RETRY_ENABLED=true

# ─── Feature Flags ───────────────────────────────────────────────────────────
# ⚪ Set to 'true' to enable the edit flow session fix.
#    Example: true
FF_EDIT_FLOW_FIX=

# ─── Vercel (Auto-injected) ───────────────────────────────────────────────────
# These are automatically set by Vercel during deployment. Do not set manually.
# NEXT_PUBLIC_VERCEL_ENV
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_AT
# VERCEL
# VERCEL_ENV
# VERCEL_GIT_COMMIT_SHA
