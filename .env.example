# ─── SmartClinic Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local

# ─── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
# For Neon: use the pooled connection string (includes "-pooler" in hostname).
#   e.g. postgresql://user:pass@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── Authentication ────────────────────────────────────────────────────────────
# Required. Secret key for signing JWT tokens. Use a long random string.
#   e.g. openssl rand -hex 32
JWT_SECRET=

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=           # Required. WhatsApp permanent access token.
WHATSAPP_PHONE_ID=        # Required. WhatsApp Phone Number ID (from Meta Business).
WHATSAPP_VERIFY_TOKEN=    # Optional. Webhook verification token. Set to any string you choose.
WHATSAPP_APP_SECRET=      # Optional but recommended. App secret for webhook signature verification.

# ─── Instagram Graph API ──────────────────────────────────────────────────────
INSTAGRAM_TOKEN=          # Required. Instagram permanent access token.
INSTAGRAM_VERIFY_TOKEN=   # Optional. Webhook verification token. Set to any string you choose.
INSTAGRAM_APP_SECRET=     # Optional but recommended. App secret for webhook signature verification.

# ─── Google Calendar (Optional) ────────────────────────────────────────────────
# Required only if you want automatic Google Calendar sync for bookings.
GOOGLE_CLIENT_ID=         # OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=     # OAuth 2.0 Client Secret
GOOGLE_REFRESH_TOKEN=     # Refresh token for offline access
GOOGLE_REDIRECT_URI=      # OAuth redirect URI (e.g. https://your-app.vercel.app/api/auth/google/callback)

# ─── Storage (Optional) ───────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=    # Vercel Blob storage token (for offer images).

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=                # Optional. One of: trace, debug, info, warn, error. Defaults to 'debug' in dev, 'info' in production.

# ─── Feature Flags ────────────────────────────────────────────────────────────
FF_EDIT_FLOW_FIX=         # Optional. Set to 'true' to enable the edit flow session fix (Phase 5).

# ─── Vercel (Auto-injected) ───────────────────────────────────────────────────
# These are automatically set by Vercel during deployment. No need to set them manually.
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_AT
# VERCEL_GIT_COMMIT_SHA
