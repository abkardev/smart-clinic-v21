# SmartClinic Test Environment
# Copy to .env.test.local and fill in your test database URL
DATABASE_URL=
JWT_SECRET=test-jwt-secret-at-least-32-chars-long-for-testing
CALENDAR_INTERNAL_SECRET=test-internal-secret-for-testing
NODE_ENV=test
LOG_LEVEL=silent
CALENDAR_RETRY_ENABLED=true
CALENDAR_RETRY_BATCH_SIZE=10
