{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true
  },
  "include": [
    "src/app/lib/googleChannels.ts",
    "src/app/lib/googleMeet.ts",
    "src/app/lib/recurringEvents.ts",
    "src/app/lib/googleCalendar.ts",
    "src/app/lib/google.ts",
    "src/app/lib/audit.ts"
  ]
}